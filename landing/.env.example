BACKEND_API_URL=http://localhost:3001
FRONTEND_APP_URL=http://localhost:3002
DISCORD_REDIRECT_URI=http://localhost:3002/api/auth/callback

# Optional: explicit dashboard URL (defaults to /dashboard)
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3002/dashboard

