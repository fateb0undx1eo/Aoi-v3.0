{
  "name": "discord-ecosystem-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch src/main.ts",
    "build": "tsc",
    "start:prod": "bun run dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:strict": "eslint --config eslint.strict.config.ts --no-config-lookup src/",
    "lint:check": "tsc --noEmit",
    "test": "bun test",
    "validate": "bun run typecheck && bun run lint:strict"
  },
  "dependencies": {
    "@discordjs/core": "^2.5.0",
    "@discordjs/rest": "^2.6.1",
    "@discordjs/ws": "^2.0.4",
    "@supabase/supabase-js": "^2.39.7",
    "bullmq": "^5.78.1",
    "@fastify/compress": "^8.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@napi-rs/canvas": "^0.1.68",
    "chroma-js": "^3.2.0",
    "discord.js": "^14.26.4",
    "fastify": "^5.3.2",
    "ioredis": "^5.11.1",
    "node-cron": "^3.0.3",
    "p-retry": "^8.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.35.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@types/pino": "^7.0.4",
    "@types/ws": "^8.18.1",
    "date-fns": "^4.4.0",
    "eslint": "^10.5.0",
    "nanoid": "^5.1.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
